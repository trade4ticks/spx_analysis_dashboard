# Copy to .env and fill in the password.
#
# App runs on the VPS alongside Postgres (Docker, localhost:5432).
# Use localhost here.
#
# For local dev on Windows, replace localhost with the VPS Tailscale IP.

DATABASE_URL=postgresql://portfolio:password@localhost:5432/spx_interpolated

# Dashboard server
HOST=0.0.0.0
PORT=8000

# Parquet data directories (comma-separated, searched in order)
PARQUET_BASES=/mnt/volume1/spx_options,/mnt/volume2/spx_options

# Anthropic API key — required for AI Surface Explorer (/ai-explorer)
ANTHROPIC_API_KEY=sk-ant-...
